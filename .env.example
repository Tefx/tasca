# Tasca Configuration
# Copy this file to .env and fill in your values.
# .env is loaded automatically by pydantic-settings (never commit it to git).
#
# All variables use the TASCA_ prefix.
# Boolean values: true / false
# List values (JSON): ["item1", "item2"]
# Unset optional values by leaving them blank or commenting them out.

# =============================================================================
# Application
# =============================================================================

# Runtime environment. Controls CSP strictness and debug behavior.
# Values: development | production
TASCA_ENVIRONMENT=development

# Enable verbose debug logging.
TASCA_DEBUG=false

# =============================================================================
# Database
# =============================================================================

# Path to the SQLite database file.
# IMPORTANT: Use an absolute path when running multiple processes (tasca-server
# + tasca-mcp), otherwise each process resolves the relative path from its own
# working directory and they end up with separate databases.
TASCA_DB_PATH=/absolute/path/to/tasca.db

# =============================================================================
# API Server
# =============================================================================

# Host and port for the uvicorn HTTP server.
TASCA_API_HOST=0.0.0.0
TASCA_API_PORT=8000

# =============================================================================
# Security — Admin Token
# =============================================================================

# Bearer token required for admin operations (create/pause/close table, etc.)
# and for MCP HTTP access (POST /mcp).
#
# HOW TO GENERATE:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# If left unset, authentication is DISABLED — any caller can perform admin
# operations. Acceptable for local development, not for production.
#
# After admin_token_fix is implemented, the server will auto-generate a token
# on startup and print it to stderr if this is not set.
TASCA_ADMIN_TOKEN=

# =============================================================================
# CORS
# =============================================================================

# Allowed origins for cross-origin requests.
# Leave empty to disable CORS entirely (same-origin only).
# Use ["*"] to allow all origins (note: credentials won't work with wildcard).
#
# Development (Vite dev server):
#   TASCA_CORS_ORIGINS=["http://localhost:5173"]
# Production (your domain):
#   TASCA_CORS_ORIGINS=["https://yourdomain.com"]
TASCA_CORS_ORIGINS=["http://localhost:5173"]

# =============================================================================
# Content Security Policy (CSP)
# =============================================================================

# Enable CSP headers. Disable only for local debugging.
TASCA_CSP_ENABLED=true

# Report-only mode: log violations without enforcing. Useful for testing
# a new CSP policy before enforcing it.
TASCA_CSP_REPORT_ONLY=false

# =============================================================================
# Server-side Limits (optional — omit or leave blank for no limit)
# =============================================================================

# Maximum number of sayings allowed per table.
# TASCA_MAX_SAYINGS_PER_TABLE=1000

# Maximum characters per saying content.
# TASCA_MAX_CONTENT_LENGTH=4096

# Maximum total bytes of saying content per table.
# TASCA_MAX_BYTES_PER_TABLE=10485760

# Maximum @mentions per saying.
# TASCA_MAX_MENTIONS_PER_SAYING=10
