#!/usr/bin/env python3
"""Repo-owned direct invar entrypoint wrapper.

This wrapper ensures direct invocation can be exercised deterministically from
repository scope without relying on host-global binary locations.
"""

from __future__ import annotations

import sys
from pathlib import Path


def main() -> None:
    """Run tasca's invar entrypoint with repo-root argv0 semantics."""

    script_path = Path(__file__).resolve()
    repo_root = script_path.parent.parent
    src_path = repo_root / "src"
    sys.path.insert(0, str(src_path))
    sys.argv[0] = str(script_path)

    from tasca_invar_entrypoint import main as entrypoint_main

    entrypoint_main()


if __name__ == "__main__":
    main()
